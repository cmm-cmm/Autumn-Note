{
  "name": "autumnnote",
  "version": "1.16.0",
  "description": "WYSIWYG rich-text editor built with vanilla JavaScript — zero dependencies, no jQuery. Dark mode, @mention, markdown shortcuts, bubble toolbar. React and Vue 3 wrappers included.",
  "type": "module",
  "main": "dist/autumnnote.cjs",
  "module": "dist/autumnnote.es.js",
  "types": "types/index.d.ts",
  "style": "dist/autumnnote.css",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/autumnnote.es.js",
      "require": "./dist/autumnnote.cjs"
    },
    "./dist/autumnnote.css": "./dist/autumnnote.css"
  },
  "files": [
    "dist",
    "src",
    "types"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.umd.config.js && vite build --config vite.cdn.config.js && node scripts/create-cjs-alias.mjs",
    "build:demo": "vite build --config vite.demo.config.js",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.js",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit && pnpm --filter autumnnote-react typecheck && pnpm --filter autumnnote-vue typecheck",
    "build:cdn": "vite build --config vite.cdn.config.js",
    "analyze": "cross-env ANALYZE=1 vite build",
    "bench": "vitest bench",
    "test:coverage": "vitest run --coverage",
    "test:wrappers": "pnpm --filter autumnnote-react test && pnpm --filter autumnnote-vue test",
    "build:wrappers": "pnpm --filter autumnnote-react build && pnpm --filter autumnnote-vue build",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm build && pnpm test:wrappers && pnpm check:bundle && pnpm build:demo && pnpm build:wrappers"
  },
  "keywords": [
    "wysiwyg",
    "wysiwyg-editor",
    "editor",
    "rich-text",
    "rich-text-editor",
    "vanilla-js",
    "vanilla-javascript",
    "contenteditable",
    "text-editor",
    "html-editor",
    "no-jquery",
    "lightweight",
    "toolbar",
    "javascript-editor",
    "summernote",
    "summernote-alternative",
    "quill-alternative",
    "tinymce-alternative",
    "markdown",
    "mention",
    "bubble-toolbar",
    "dark-mode",
    "i18n",
    "typescript",
    "esm",
    "javascript-wysiwyg",
    "wysiwyg-vanilla",
    "froala-alternative",
    "ckeditor-alternative",
    "zero-dependencies",
    "react-wysiwyg",
    "vue-wysiwyg",
    "prosemirror-alternative",
    "trix-alternative",
    "slate-alternative",
    "vue3",
    "quill",
    "tinymce",
    "react",
    "vue",
    "plugin-api",
    "rtl",
    "autosave"
  ],
  "homepage": "https://autumn.konexforge.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmm-cmm/Autumn-Note.git"
  },
  "bugs": {
    "url": "https://github.com/cmm-cmm/Autumn-Note/issues"
  },
  "author": "Minh Pham",
  "license": "MIT",
  "devDependencies": {
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.8",
    "cross-env": "^10.1.0",
    "eslint": "10.7.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.61.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.101.0",
    "typescript": "^6.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20.19.0"
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "> 0.5%"
  ]
}
