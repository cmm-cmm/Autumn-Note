{
  "name": "autumnnote",
  "version": "1.0.1",
  "description": "A modern, lightweight WYSIWYG editor — built with vanilla JavaScript, no jQuery required.",
  "main": "dist/autumnnote.umd.js",
  "module": "dist/autumnnote.es.js",
  "types": "types/index.d.ts",
  "style": "dist/autumnnote.css",
  "files": [
    "dist",
    "src",
    "types"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.umd.config.js",
    "build:demo": "vite build --config vite.demo.config.js",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .js"
  },
  "keywords": [
    "wysiwyg",
    "editor",
    "rich-text",
    "rich-text-editor",
    "vanilla-js",
    "vanilla-javascript",
    "contenteditable",
    "summernote",
    "text-editor",
    "html-editor",
    "no-jquery",
    "lightweight",
    "toolbar",
    "javascript-editor"
  ],
  "author": "Minh Pham",
  "license": "MIT",
  "devDependencies": {
    "@vitest/browser": "^1.0.0",
    "eslint": "^8.57.0",
    "jsdom": "^29.0.1",
    "sass": "^1.77.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "> 0.5%"
  ]
}
