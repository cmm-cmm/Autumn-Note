{
  "name": "autumnnote",
  "version": "1.0.9",
  "description": "A modern, lightweight WYSIWYG editor — built with vanilla JavaScript, no jQuery required.",
  "main": "dist/autumnnote.umd.js",
  "module": "dist/autumnnote.es.js",
  "types": "types/index.d.ts",
  "style": "dist/autumnnote.css",
  "files": [
    "dist",
    "src",
    "types"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.umd.config.js",
    "build:demo": "vite build --config vite.demo.config.js",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "build:cdn": "vite build --config vite.cdn.config.js",
    "analyze": "cross-env ANALYZE=1 vite build",
    "bench": "vitest bench"
  },
  "keywords": [
    "wysiwyg",
    "editor",
    "rich-text",
    "rich-text-editor",
    "vanilla-js",
    "vanilla-javascript",
    "contenteditable",
    "summernote",
    "text-editor",
    "html-editor",
    "no-jquery",
    "lightweight",
    "toolbar",
    "javascript-editor"
  ],
  "author": "Minh Pham",
  "license": "MIT",
  "devDependencies": {
    "@vitest/browser": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "jsdom": "^25.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.99.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "> 0.5%"
  ]
}
