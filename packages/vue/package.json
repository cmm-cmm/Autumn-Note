{
  "name": "autumnnote-vue",
  "version": "1.7.0",
  "description": "Official Vue 3 wrapper for AutumnNote — zero-dependency WYSIWYG editor. Mount the editor with a single component and access the full Context API via ref.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "index.d.ts"
  ],
  "scripts": {
    "build": "vite build"
  },
  "keywords": [
    "wysiwyg",
    "wysiwyg-editor",
    "rich-text",
    "rich-text-editor",
    "vue",
    "vue3",
    "vue-wysiwyg",
    "vue-editor",
    "vue-rich-text",
    "vue-component",
    "contenteditable",
    "no-jquery",
    "vanilla-js",
    "dark-mode",
    "markdown",
    "mention",
    "bubble-toolbar",
    "toolbar",
    "autumnnote",
    "summernote-alternative",
    "quill-alternative",
    "tinymce-alternative"
  ],
  "homepage": "https://cmm-cmm.github.io/Autumn-Note/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmm-cmm/Autumn-Note.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/cmm-cmm/Autumn-Note/issues"
  },
  "author": "Minh Pham",
  "license": "MIT",
  "peerDependencies": {
    "autumnnote": ">=1.4.0",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "autumnnote": "workspace:*",
    "vite": "^6.0.0",
    "vue": "^3.4.0"
  }
}
