{
  "name": "autumnnote-react",
  "version": "1.15.0",
  "description": "Official React wrapper for Autumn Note — zero-dependency WYSIWYG editor. Mount the editor with a single component and access the full Context API via ref.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "index.d.ts"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.test.json"
  },
  "keywords": [
    "wysiwyg",
    "wysiwyg-editor",
    "rich-text",
    "rich-text-editor",
    "react",
    "react-wysiwyg",
    "react-editor",
    "react-rich-text",
    "react-component",
    "contenteditable",
    "no-jquery",
    "vanilla-js",
    "dark-mode",
    "markdown",
    "mention",
    "bubble-toolbar",
    "toolbar",
    "autumnnote",
    "summernote-alternative",
    "quill-alternative",
    "tinymce-alternative"
  ],
  "homepage": "https://autumn.konexforge.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmm-cmm/Autumn-Note.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/cmm-cmm/Autumn-Note/issues"
  },
  "author": "Minh Pham",
  "license": "MIT",
  "peerDependencies": {
    "autumnnote": ">=1.4.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autumnnote": "workspace:*",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "vite": "^8.1.5"
  }
}
